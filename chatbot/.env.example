# ============================================
# FAQ Chatbot Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# === Required: Anthropic API Key ===
# Get your API key from: https://console.anthropic.com/
# This is needed to use Claude for generating responses
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# === Optional: Your Law Firm's Name ===
# This will appear in the chatbot's responses
# Example: "Smith & Associates Immigration Law"
FIRM_NAME=Your Law Firm Name
