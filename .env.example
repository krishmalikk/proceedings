# ===========================================
# Proceedings RAG Pipeline — Environment Variables
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ===========================================

# GCP Configuration
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GCP_BUCKET_NAME=your-bucket-name

# Firecrawl API
FIRECRAWL_API_KEY=your-firecrawl-api-key

# Vertex AI Vector Search
# (These are created when you run index.py for the first time)
VERTEX_AI_INDEX_ID=your-index-id
VERTEX_AI_INDEX_ENDPOINT_ID=your-index-endpoint-id

# Label Studio (optional — only needed if automating Label Studio via API)
LABEL_STUDIO_URL=http://localhost:8080
LABEL_STUDIO_API_KEY=your-label-studio-api-key

# Google Custom Search (optional — for discover_urls.py)
GOOGLE_SEARCH_API_KEY=your-google-search-api-key
GOOGLE_SEARCH_ENGINE_ID=your-search-engine-id
